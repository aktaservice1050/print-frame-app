generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id            String   @id
  shop          String
  state         String
  isOnline      Boolean  @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean?
  locale        String?
  collaborator  Boolean?
  emailVerified Boolean?
}

model OrderQueue {
  id                 String   @id @default(cuid())

  shopifyOrderId      String   @unique
  orderNumber         String
  customerEmail       String?
  rawCurrency         String?

  status              String   @default("pending") // pending | editable | sent | failed
  needsEdit           Boolean  @default(false)
  partnerPayload      Json
  partnerApiStatus    Int?
  partnerApiResponse  Json?

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([status])
  @@index([orderNumber])
}
